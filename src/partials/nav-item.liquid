<li>
  <a
    class="text-primary after:bg-primary hocus:brightness-100 hocus:after:brightness-100 {% if page.url == link %}brightness-75 after:brightness-75{% else %}brightness-90 after:brightness-90{% endif %}"
    href="{{ link }}"
    {% if page.url == 'link' %}
      aria-current="page"
    {% endif %}>
    {{ title }}
  </a>
</li>
