---
layout: "page"
title: Blog
eleventyImport:
  collections: ["post"]
---
<ul>
  {%- for post in collections.post reversed -%}
    <li>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
      {%- if post.data.date -%}
        <span class="text-base text-diminished ml-4">{{ post.data.date | date: '%Y-%m-%d' }}</span>
      {%- endif -%}
    </li>
  {%- endfor -%}
</ul>
